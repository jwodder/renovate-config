{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
        "schedule:weekly",
        ":gitSignOff",
    ],
    "enabledManagers": [
        "cargo",
        "github-actions",
        "pep621",
        "pip_requirements",
    ],
    "automergeStrategy": "rebase",
    "assignees": ["jwodder"],
    "commitBodyTable": true,
    "commitMessageLowerCase": "never",
    "dependencyDashboardLabels": ["CI", "dashboard", "dependencies"],
    "dependencyDashboardTitle": "Renovate Dependency Dashboard",
    "labels": ["dependencies"],
    "semanticCommits": "disabled",
    "separateMajorMinor": false,
    "timezone": "America/New_York",

    "cargo": {
        "addLabels": ["d:cargo"],
        "automerge": true,
        "commitMessagePrefix": "[cargo]",
        "lockFileMaintenance": {
            "enabled": true,
            "extends": ["schedule:monthly"],
            "commitMessageAction": "Autoupdate Cargo.lock",
        },
        "rangeStrategy": "update-lockfile",
    },

    "github-actions": {
        "addLabels": ["d:github-actions"],
        "commitMessagePrefix": "[github-actions]",
        "extends": [
            "helpers:pinGitHubActionDigestsToSemver",
            "schedule:monthly",
        ],
    },

    "pep621": {
        "addLabels": ["d:python"],
        "commitMessagePrefix": "[python]",
        "rangeStrategy": "replace",
    },

    "pip_requirements": {
        "addLabels": ["d:python"],
        "commitMessagePrefix": "[python]",
        "rangeStrategy": "replace",
    },

    "packageRules": [
        {
            "groupName": "Cargo non-breaking updates (0.x)",
            "matchManagers": ["cargo"],
            "matchCurrentVersion": "<1.0.0",
            "matchUpdateTypes": ["patch"],
            "enabled": false,  // Only update via monthly lockfile maintenance
        },
        {
            "groupName": "Cargo non-breaking updates (x.y)",
            "matchManagers": ["cargo"],
            "matchCurrentVersion": ">=1.0.0",
            "matchUpdateTypes": ["minor", "patch"],
            "enabled": false,  // Only update via monthly lockfile maintenance
        },
        {
            "groupName": "rand dependencies",
            "matchManagers": ["cargo"],
            "matchPackageNames": ["rand", "rand_chacha"],
        },
        {
            "groupName": "rstest dependencies",
            "matchManagers": ["cargo"],
            "matchPackageNames": ["rstest", "rstest_reuse"],
        },
        {
            "groupName": "RustCrypto dependencies",
            "matchManagers": ["cargo"],
            "matchPackageNames": [
                "cipher",
                "digest",
                "hmac",
                "md-5",
                "pbkdf2",
                "rc4",
                "sha1",
                "sha2",
            ]
        },
        {
            "groupName": "GitHub Actions non-breaking updates (disabled)",
            "matchManagers": ["github-actions"],
            "matchCurrentVersion": ">=1.0.0",
            "matchUpdateTypes": ["minor", "patch"],
            "enabled": false,
        },
        {
            "matchFileNames": ["docs/requirements.txt"],
            "commitMessagePrefix": "[python+docs]",
        },
    ],
}
